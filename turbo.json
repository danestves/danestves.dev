{
  "$schema": "https://turborepo.org/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "public/**", "package.json", "tsconfig.json"],
      "outputs": ["dist/**", "build/**", "public/**"]
    },
    "dev": {
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "serve": {
      "cache": false,
      "dependsOn": ["^serve"]
    }
  },
  "globalEnv": ["GITHUB_TOKEN"]
}
