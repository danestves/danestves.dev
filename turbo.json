{
  "$schema": "https://turborepo.org/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", "public/**"]
    },
    "dev": {
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "serve": {
      "cache": false,
      "dependsOn": ["^serve"]
    }
  },
  "globalEnv": [
    "PAYLOAD_CONFIG_PATH",
    "PAYLOADCMS_SECRET",
    "MONGODB_URL",
    "NODE_ENV",
    "PORT"
  ]
}
