{
  "name": "@danestves/web",
  "version": "0.0.0",
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./build/index.js",
      "require": "./build/index.js"
    },
    "./express": {
      "import": "./express.js",
      "require": "./express.js"
    }
  },
  "scripts": {
    "postinstall": "patch-package --patch-dir other/patches",
    "clean": "rimraf node_modules build public/build .turbo",
    "build": "remix build && tsx ./other/generate-build-info",
    "dev": "remix build && run-p \"dev:*\"",
    "dev:remix": "remix dev",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint --ext js,jsx,ts,tsx --resolve-plugins-relative-to ."
  },
  "prettier": "@danestves/prettier-config",
  "eslintConfig": {
    "extends": "@danestves/eslint-config/react-remix"
  },
  "dependencies": {
    "@keystatic/core": "0.0.59",
    "@keystatic/remix": "0.0.2",
    "@remix-run/express": "1.14.0",
    "@remix-run/node": "1.14.0",
    "@remix-run/react": "1.14.0",
    "@remix-run/server-runtime": "1.14.0",
    "escape-html": "1.0.3",
    "isbot": "3.6.6",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@danestves/eslint-config": "workspace:*",
    "@danestves/prettier-config": "workspace:*",
    "@milahu/patch-package": "6.4.14",
    "@remix-run/dev": "1.14.0",
    "@remix-run/eslint-config": "1.14.0",
    "@types/escape-html": "1.0.2",
    "@types/react": "18.0.28",
    "@types/react-dom": "18.0.11",
    "autoprefixer": "10.4.13",
    "cssnano": "5.1.15",
    "npm-run-all": "4.1.5",
    "postcss-import": "15.1.0",
    "react-refresh": "0.14.0",
    "tailwindcss": "3.2.7",
    "tsx": "3.12.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
