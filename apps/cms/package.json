{
  "name": "@danestves/cms",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "exports": {
    ".": {
      "serve": {
        "types": "./dist/index.js",
        "require": "./dist/index.js",
        "import": "./dist/index.js"
      },
      "default": {
        "types": "./src/index.ts",
        "require": "./src/index.ts",
        "import": "./src/index.ts"
      }
    },
    "./types": {
      "types": "./src/payload-types.ts",
      "require": "./src/payload-types.ts",
      "import": "./src/payload-types.ts"
    }
  },
  "types": "./src/index.ts",
  "scripts": {
    "build": "pnpm build:payload && pnpm build:server && pnpm copyfiles",
    "build:payload": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload build",
    "build:server": "rimraf dist/* && tsc",
    "clean": "rimraf node_modules dist build .turbo",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{html,css,scss,ttf,woff,woff2,eot,svg,jpg,png}\" build/ dist/ && copyfiles -u 1 \"build/**/*\" ../server/build",
    "generate:graphQLSchema": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:graphQLSchema",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types"
  },
  "prettier": "@danestves/prettier-config",
  "eslintConfig": {
    "extends": "@danestves/eslint-config/react"
  },
  "dependencies": {
    "payload": "1.6.9"
  },
  "devDependencies": {
    "@danestves/eslint-config": "workspace:*",
    "@danestves/prettier-config": "workspace:*",
    "@faceless-ui/modal": "2.0.1",
    "@types/react": "18.0.28",
    "@types/react-dom": "18.0.10",
    "@types/react-router-dom": "5.3.3",
    "copyfiles": "2.4.1",
    "cross-env": "7.0.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-router-dom": "5.3.4",
    "slate": "0.88.1",
    "slate-react": "0.88.0",
    "ts-node": "10.9.1",
    "typescript": "4.9.5"
  }
}
