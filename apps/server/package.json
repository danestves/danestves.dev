{
  "name": "@danestves/server",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm build:server && pnpm copyfiles",
    "build:server": "rimraf dist/* && tsc",
    "clean": "rimraf node_modules build dist .turbo",
    "copyfiles": "copyfiles -u 1 \"src/**/*.txt\" dist/",
    "dev": "cross-env PAYLOAD_CONFIG_PATH=../cms/src/payload.config.ts NODE_ENV=development nodemon",
    "serve": "cross-env PAYLOAD_CONFIG_PATH=../cms/dist/payload.config.js NODE_ENV=production node --conditions=serve dist/index.js"
  },
  "prettier": "@danestves/prettier-config",
  "eslintConfig": {
    "extends": "@danestves/eslint-config/node"
  },
  "dependencies": {
    "@danestves/cms": "workspace:*",
    "@danestves/web": "workspace:*",
    "@types/compression": "1.7.2",
    "@types/on-finished": "2.3.1",
    "compression": "1.7.4",
    "express": "4.18.2",
    "express-prom-bundle": "6.6.0",
    "helmet": "6.0.1",
    "morgan": "1.10.0",
    "on-finished": "2.4.1",
    "path-to-regexp": "6.2.1",
    "prom-client": "14.1.1",
    "server-timing": "3.3.3"
  },
  "devDependencies": {
    "@danestves/eslint-config": "workspace:*",
    "@danestves/prettier-config": "workspace:*",
    "@types/express": "4.17.17",
    "@types/morgan": "1.9.4",
    "@types/node": "18.13.0",
    "copyfiles": "2.4.1",
    "cross-env": "7.0.3",
    "nodemon": "2.0.20",
    "ts-node": "10.9.1",
    "typescript": "4.9.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
